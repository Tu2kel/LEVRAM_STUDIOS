#project-battery-host,
.levram-battery-dock {
  grid-column: 1 / -1;
  width: 100%;
  max-width: none;
  margin: 12px 14px 8px;
  font-family: Rajdhani, sans-serif;
}

.pb-shell {
  background: linear-gradient(160deg, #111 0%, #080808 100%);
  border: 1px solid rgba(201, 168, 76, 0.35);
  border-top: 1px solid rgba(249, 242, 149, 0.65);
  border-radius: 14px;
  padding: 22px 28px 20px;
  box-shadow:
    0 0 35px rgba(201, 168, 76, 0.12),
    inset 0 0 30px rgba(201, 168, 76, 0.05);
}

.pb-top {
  display: flex;
  justify-content: space-between;
  gap: 20px;
  margin-bottom: 20px;
}

.pb-eyebrow {
  color: #8b6914;
  font-size: 11px;
  letter-spacing: 4px;
  text-transform: uppercase;
  font-weight: 900;
}

.pb-project-name {
  color: #fff;
  font-size: 28px;
  letter-spacing: 3px;
  text-transform: uppercase;
  font-weight: 900;
  margin-top: 6px;
}

.pb-progress-block {
  text-align: center;
  min-width: 95px;
}

.pb-progress-label,
.pb-fraction span {
  color: #777;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
}

.pb-ring-wrap {
  position: relative;
  width: 78px;
  height: 78px;
  margin: 6px auto;
}

.pb-ring-bg {
  fill: none;
  stroke: rgba(255, 255, 255, 0.08);
  stroke-width: 5;
}

.pb-ring-fill {
  fill: none;
  stroke: #c9a84c;
  stroke-width: 5;
  stroke-linecap: round;
  transition: stroke-dashoffset 1s ease;
}

.pb-ring-pct {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #f9f295;
  font-weight: 900;
}

.pb-fraction {
  color: #c9a84c;
  font-size: 13px;
  font-weight: 900;
}

.pb-fraction span {
  display: block;
}

.pb-track-wrap {
  position: relative;
  margin: 10px 0 18px;
}

.pb-track-line {
  position: absolute;
  top: 50%;
  left: 0;
  right: 0;
  height: 2px;
  background: rgba(255, 255, 255, 0.08);
}

.pb-track-line-fill {
  height: 100%;
  background: linear-gradient(90deg, #8b6914, #c9a84c);
  transition: width 1s ease;
}

.pb-track-dots {
  display: none;
}

.pb-stages {
  display: flex;
  gap: 2px;
  position: relative;
}

.pb-stage {
  flex: 1;
  height: 86px;
  background: #131313;
  color: #777;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  clip-path: polygon(
    0 0,
    calc(100% - 15px) 0,
    100% 50%,
    calc(100% - 15px) 100%,
    0 100%,
    15px 50%
  );
}

.pb-stage:first-child {
  clip-path: polygon(
    0 0,
    calc(100% - 15px) 0,
    100% 50%,
    calc(100% - 15px) 100%,
    0 100%
  );
}

.pb-stage:last-child {
  clip-path: polygon(0 0, 100% 0, 100% 100%, 0 100%, 15px 50%);
}

.pb-stage.done {
  color: #8b6914;
}

.pb-stage.active {
  color: #f9f295;
  background: linear-gradient(160deg, #2a1b00, #080600);
  filter: drop-shadow(0 0 18px rgba(201, 168, 76, 0.35));
}

.pb-stage-icon svg {
  width: 30px;
  height: 30px;
  margin-bottom: 7px;
}

.pb-stage-name {
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-weight: 900;
}

.pb-stage-num {
  font-size: 10px;
  opacity: 0.5;
}

.pb-status-bar {
  display: flex;
  justify-content: space-between;
  gap: 20px;
  background: rgba(255, 255, 255, 0.025);
  border: 1px solid rgba(255, 255, 255, 0.07);
  border-radius: 10px;
  padding: 14px 20px;
}

.pb-status-label {
  color: #c9a84c;
  font-size: 10px;
  letter-spacing: 3px;
  text-transform: uppercase;
}

.pb-status-label.green {
  color: #00c060;
}

.pb-status-title {
  color: #fff;
  font-size: 14px;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-weight: 900;
}

.pb-status-sub {
  color: #888;
  font-size: 12px;
}

.pb-status-icon,
.pb-arrow-sep {
  display: none;
}

.pb-bar-wrap {
  height: 4px;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 999px;
  margin-top: 16px;
  position: relative;
}

.pb-bar-fill {
  height: 100%;
  background: linear-gradient(90deg, #8b6914, #c9a84c, #f9f295);
  box-shadow: 0 0 12px rgba(201, 168, 76, 0.6);
  transition: width 1s ease;
}

.pb-bar-dot,
.pb-bar-labels {
  display: none;
}

.pb-tagline {
  text-align: center;
  margin-top: 12px;
  color: rgba(255, 255, 255, 0.22);
  letter-spacing: 5px;
  text-transform: uppercase;
  font-size: 10px;
}


.pb-shell {
  position: relative;
  overflow: hidden;
}

  to {
    left: 105%;
  }
}

.pb-stage.active {
  position: relative;
  overflow: hidden;
}

.pb-stage.active::after {
  content: "";
  position: absolute;
  top: 8%;
  left: -18%;
  width: 14%;
  height: 84%;

  background: linear-gradient(
    90deg,
    transparent,
    rgba(249,242,149,.08),
    rgba(255,255,255,.45),
    rgba(249,242,149,.08),
    transparent
  );

  transform: skewX(-22deg);

  animation: activeChevronGlint 2.8s ease-in-out infinite alternate;

  pointer-events: none;
}

@keyframes activeChevronGlint {
  from {
    left: -18%;
  }

  to {
    left: 102%;
  }
}


#project-battery-host {
  margin-bottom: 18px;
}

.main-grid {
  grid-auto-rows: auto;
  align-items: start;
}

.left-panel,
.right-panel {
  min-height: 0;
}

.preview-row,
.timeline-row {
  min-height: 220px;
}

/* FIX: stop preview/timeline overlay after battery spacing update */
.main-grid {
  display: grid;
  grid-template-rows: auto auto auto !important;
  grid-auto-rows: auto !important;
  align-items: start !important;
  gap: 14px !important;
}

.preview-row,
.timeline-row {
  position: relative !important;
  min-height: 260px !important;
  height: auto !important;
  overflow: visible !important;
  z-index: 1;
}

.timeline-row {
  margin-top: 12px !important;
}

#project-battery-host {
  position: relative !important;
  z-index: 2;
  margin-bottom: 18px !important;
}

.left-panel,
.right-panel {
  min-height: 0 !important;
  height: auto !important;
  overflow: visible !important;
}
