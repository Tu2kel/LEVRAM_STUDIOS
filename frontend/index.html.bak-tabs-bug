<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LEVRAM Generator</title>
    <link rel="stylesheet" href="app.css">
<link rel="stylesheet" href="project-battery.css">

  
<style>
.render-status-pill {
  display: inline-block;
  padding: 4px 10px;
  border-radius: 999px;
  font-weight: 700;
  text-transform: uppercase;
  font-size: 0.78rem;
}

.render-status-pending {
  color: #ffd166;
  border: 1px solid #ffd166;
}

.render-status-rendering {
  color: #00d4ff;
  border: 1px solid #00d4ff;
}

.render-status-complete {
  color: #00ff88;
  border: 1px solid #00ff88;
}

.render-status-failed {
  color: #ff4d6d;
  border: 1px solid #ff4d6d;
}

.render-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  margin-top: 10px;
}

.render-actions button {
  padding: 7px 11px;
  border-radius: 8px;
  border: 1px solid #C9A84C;
  background: #160008;
  color: #C9A84C;
  cursor: pointer;
  font-weight: 700;
}

.render-actions button:hover {
  background: #2a000a;
}
</style>

</head>
  <body>
    <!-- TOP BAR -->
    <header class="top-bar">
      <div class="logo">
        <span class="logo-text">LEVRAM</span>
        <span class="logo-sub">Generator v2</span>
      </div>
      <nav class="top-nav">
        <button class="nav-btn active">Voice Lab</button>
        <button class="nav-btn">Idea Vault</button>
        <button class="nav-btn">Shot Builder</button>
        <button class="nav-btn">Image Gen</button>
        <button class="nav-btn">Timeline</button>
        <button class="nav-btn">Export</button>
        <button id="theme-toggle" class="nav-btn">Ivory Mode</button>
      </nav>
      <div class="status-pill">
        <span class="status-dot"></span>
        Backend Connected
      </div>
    </header>

    <!-- MAIN LAYOUT -->
    <div class="main-grid">
      <div id="project-battery-host" class="levram-battery-dock"></div>
      <!-- LEFT: VOICE LAB -->
      <div class="left-panel">
        <div class="panel-header">
          <div class="panel-header-icon red">
            <svg viewBox="0 0 16 16">
              <path d="M8 1a3 3 0 0 0-3 3v5a3 3 0 0 0 6 0V4a3 3 0 0 0-3-3z" />
              <path d="M3 9a5 5 0 0 0 10 0" />
            </svg>
          </div>
          <span class="panel-title">Voice Lab</span>
          <span class="panel-badge">Live</span>
        </div>

        <div class="voice-lab">
          <div class="field-group">
            <div class="field-label">Script / Line</div>
            <textarea
              id="script-input"
              class="script-input"
              placeholder="They left me for dead. Every god abandons their creation eventually. I just decided not to let it end there."
            >
They left me for dead.</textarea
            >
          </div>

          <div class="field-group">
            <div class="field-label">Character</div>
            <div class="char-presets">
              <button class="char-btn active">Hulk</button>
              <button class="char-btn">Wally</button>
              <button class="char-btn">Barry</button>
              <button class="char-btn">Narrator</button>
              <button class="char-btn">Female</button>
              <button class="char-btn">+ Custom</button>
            </div>
          </div>

          <div class="gold-divider"></div>

          <div class="field-group">
            <div class="field-label">Voice FX Preset</div>
            <select class="fx-preset">
              <option value="villain">Villain — Dark & Reverbed</option>
              <option value="deep">Deep — Pure Bass Shift</option>
              <option value="monster">Monster — Chorus + Growl</option>
              <option value="ghost">Ghost — Echo Chamber</option>
              <option value="radio">Radio — Lo-Fi Filter</option>
              <option value="clean">Clean — No FX</option>
            </select>
          </div>

          <div class="field-group">
            <div class="field-label">FX Parameters</div>
            <div class="fx-grid">
              <div class="slider-row">
                <span class="slider-name">Pitch Shift</span>
                <input
                  type="range"
                  min="0"
                  max="100"
                  value="35"
                  oninput="
                    this.nextElementSibling.textContent = this.value + '%'
                  "
                />
                <span class="slider-val">35%</span>
              </div>
              <div class="slider-row">
                <span class="slider-name">Reverb</span>
                <input
                  type="range"
                  min="0"
                  max="100"
                  value="55"
                  oninput="
                    this.nextElementSibling.textContent = this.value + '%'
                  "
                />
                <span class="slider-val">55%</span>
              </div>
              <div class="slider-row">
                <span class="slider-name">Timbre</span>
                <input
                  type="range"
                  min="0"
                  max="100"
                  value="70"
                  oninput="
                    this.nextElementSibling.textContent = this.value + '%'
                  "
                />
                <span class="slider-val">70%</span>
              </div>
              <div class="slider-row">
                <span class="slider-name">Distortion</span>
                <input
                  type="range"
                  min="0"
                  max="100"
                  value="20"
                  oninput="
                    this.nextElementSibling.textContent = this.value + '%'
                  "
                />
                <span class="slider-val">20%</span>
              </div>
              <div class="slider-row">
                <span class="slider-name">Volume</span>
                <input
                  type="range"
                  min="0"
                  max="100"
                  value="80"
                  oninput="
                    this.nextElementSibling.textContent = this.value + '%'
                  "
                />
                <span class="slider-val">80%</span>
              </div>
            </div>
          </div>

          <button
            id="btn-fx"
            class="gen-btn"
            style="
              background: linear-gradient(90deg, #1f4fa3, #2e6fd4, #1f4fa3);
              margin-bottom: 8px;
              font-size: 17px;
              letter-spacing: 4px;
            "
          >
            Apply Voice FX
          </button>
          <button id="btn-generate" class="gen-btn">Generate Voice</button>
          <p id="status-text" class="status">Ready</p>
        </div>
      </div>


      <!-- RIGHT: SHOT BUILDER -->
      <div class="right-panel">
        <div class="panel-header">
          <div class="panel-header-icon blue">
            <svg viewBox="0 0 16 16" fill="white">
              <path
                d="M1 4a1 1 0 0 1 1-1h12a1 1 0 0 1 1 1v8a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V4zm5 4l4-2.5v5L6 8z"
              />
            </svg>
          </div>
          <span class="panel-title">Shot Builder</span>
        </div>

        <div class="shot-builder">
          <div class="shot-grid">
            <div class="shot-field">
              <div class="field-label">Project</div>
              <select id="shot-project">
                <option>The Runner</option>
                <option>The Other Side</option>
                <option>Levram Banner</option>
              </select>
            </div>
            <div class="shot-field">
              <div class="field-label">Scene #</div>
              <input id="shot-scene" type="text" placeholder="SC-004" />
            </div>
            <div class="shot-field">
              <div class="field-label">Shot Type</div>
              <select id="shot-type">
                <option>Extreme Close-Up</option>
                <option>Close-Up</option>
                <option>Medium Shot</option>
                <option>Wide Shot</option>
                <option>Bird's Eye</option>
                <option>Ground Level</option>
                <option>Tracking Shot</option>
              </select>
            </div>
            <div class="shot-field">
              <div class="field-label">Camera Mood</div>
              <select id="shot-camera">
                <option>Slow / Heavy / Suffocating</option>
                <option>Violently Disorienting</option>
                <option>Dreamlike / Still / Vast</option>
                <option>Intimate / Invasive</option>
                <option>Civilian POV</option>
              </select>
            </div>
            <div class="shot-field">
              <div class="field-label">Color Palette</div>
              <select id="shot-palette">
                <option>Cold Blue-White (Runner)</option>
                <option>Amber Dying to Ash (Other Side)</option>
                <option>Bio-Green + Supernova Red (Banner)</option>
                <option>Dark Neon / Rain</option>
                <option>Custom</option>
              </select>
            </div>
            <div class="shot-field">
              <div class="field-label">AI Engine</div>
              <select id="shot-engine">
                <option>Imperio AI</option>
              </select>
            </div>
            <div class="shot-field" style="grid-column: 1/-1">
              <div class="field-label">Shot Description</div>
              <textarea
                id="shot-desc"
                style="
                  width: 100%;
                  background: #0b0b0b;
                  border: 1px solid rgba(201, 168, 76, 0.2);
                  border-bottom: 1px solid rgba(201, 168, 76, 0.5);
                  color: #000000;
                  font-family: Rajdhani, sans-serif;
                  font-size: 16px;
                  padding: 10px 12px;
                  border-radius: 4px;
                  resize: none;
                  outline: none;
                  height: 60px;
                "
                placeholder="What physically happens in this shot..."
              ></textarea>
            </div>
            <div class="shot-field shot-prompt">
              <div class="field-label">Shot Prompt</div>
              <textarea
                id="shot-prompt-input"
                placeholder="Describe the shot — atmosphere, subject, lighting, emotion. LEVRAM rules apply automatically."
              >
Ground-level civilian POV. Rubble. A child alone on a cracked sidewalk. Emergency sirens, no one answers. Blue-white speed blur in the sky above — too fast, too clean. The hero never looked back.</textarea
              >
            </div>
            <div class="shot-field" style="grid-column: 1 / 3">
              <div class="field-label">Character</div>
              <input
                id="shot-char-override"
                type="text"
                placeholder="Wally / Barry / Hulk / Original..."
              />
            </div>
            <div class="shot-field">
              <div class="field-label">Duration</div>
              <select id="shot-duration">
                <option>2s</option>
                <option selected>4s</option>
                <option>16s</option>
              </select>
            </div>
          </div>
          <button id="btn-save-shot" class="build-shot-btn">
            Save Shot Card
          </button>
        </div>
      </div>

      <!-- BOTTOM LEFT + RIGHT: PREVIEW SPANNING FULL WIDTH -->
      <div class="preview-row" style="grid-column: 1 / -1">
        <div class="panel-header" style="padding: 8px 20px">
          <div class="panel-header-icon gold">
            <svg viewBox="0 0 16 16" fill="black">
              <path d="M3 3h10v10H3z" />
            </svg>
          </div>
          <span class="panel-title">Preview / Generated Output</span>
          <div style="margin-left: auto; display: flex; gap: 8px">
            <a
              id="dl-raw"
              download
              style="
                background: transparent;
                border: 1px solid var(--border);
                color: var(--text-muted);
                font-family: Rajdhani, sans-serif;
                font-size: 13px;
                letter-spacing: 2px;
                text-transform: uppercase;
                padding: 4px 12px;
                border-radius: 2px;
                cursor: pointer;
                text-decoration: none;
                display: inline-block;
              "
              >Download Raw</a
            >
            <a
              id="dl-fx"
              download
              style="
                background: transparent;
                border: 1px solid var(--border-strong);
                color: var(--gold);
                font-family: Rajdhani, sans-serif;
                font-size: 13px;
                letter-spacing: 2px;
                text-transform: uppercase;
                padding: 4px 12px;
                border-radius: 2px;
                cursor: pointer;
                text-decoration: none;
                display: inline-block;
              "
              >Download FX</a
            >
          </div>
        </div>
        <div class="preview-inner">
          <div id="preview-main" class="preview-main">
            <div class="preview-placeholder">
              <span class="big-icon">▶</span>
              <p>No output yet — generate voice or build shot</p>
            </div>
          </div>
          <div class="preview-meta">
            <div class="meta-item">
              <span class="meta-label">Character</span>
              <span id="meta-char" class="meta-val gold">Hulk</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Preset</span>
              <span id="meta-preset" class="meta-val">Villain</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Engine</span>
              <span class="meta-val">Spark-TTS</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">FX Status</span>
              <span id="meta-fx-status" class="meta-val red">Pending</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Duration</span>
              <span id="meta-duration" class="meta-val">—</span>
            </div>
            <div class="meta-item">
              <span class="meta-label">Project</span>
              <span class="meta-val blue">The Runner</span>
            </div>
          </div>
        </div>
        <div id="waveform-area" class="waveform-area">
          <span
            style="
              font-size: 12px;
              letter-spacing: 3px;
              text-transform: uppercase;
              color: var(--text-dim);
              font-weight: 600;
              margin-right: 12px;
              white-space: nowrap;
            "
            >Waveform</span
          >
          <!-- Waveform bars -->
          
        </div>
      </div>

      <!-- TIMELINE SPANNING FULL WIDTH -->
      <div id="timeline-workspace" class="timeline-row" style="grid-column: 1 / -1">
        <div class="timeline-header">
          <span class="panel-title" style="font-size: 15px; letter-spacing: 5px"
            >Shot History / Timeline</span
          >
          <div style="display: flex; gap: 8px; margin-left: 16px">
            <button
              id="btn-clear"
              style="
                background: transparent;
                border: 1px solid var(--border);
                color: var(--text-muted);
                font-family: Rajdhani, sans-serif;
                font-size: 12px;
                letter-spacing: 2px;
                text-transform: uppercase;
                padding: 3px 10px;
                border-radius: 2px;
                cursor: pointer;
              "
            >
              Clear
            </button>
            <button
              id="btn-save-timeline-order"
              style="
                background: transparent;
                border: 1px solid var(--border);
                color: var(--gold);
                font-family: Rajdhani, sans-serif;
                font-size: 12px;
                letter-spacing: 2px;
                text-transform: uppercase;
                padding: 3px 10px;
                border-radius: 2px;
                cursor: pointer;
              "
            >
              Save Order
            </button>
          </div>
          <span id="tl-time" class="tl-time">00:00:00 / 00:00:00</span>
        </div>
        <div class="timeline-tracks">
          <div class="track">
            <span class="track-label">Voice</span>
            <div id="track-voice-body" class="track-body">
              <div class="track-clip voice">
                Hulk — "They left me for dead."
              </div>
            </div>
          </div>
          <div class="track">
            <span class="track-label">FX</span>
            <div id="track-fx-body" class="track-body">
              <div class="track-clip fx">Villain Preset</div>
            </div>
          </div>
          <div class="track">
            <span class="track-label">Shots</span>
            <div id="track-shot-body" class="track-body">
              <div class="track-clip shot">SC-001 Close</div>
              <div class="track-clip shot2">SC-002 Ground Level</div>
            </div>
          </div>
        </div>
        <div
          id="timeline-shots"
          style="
            max-height: 70vh; overflow-y: auto; padding-right: 6px;
            flex: 0 0 auto;
            padding: 10px 20px 6px 20px;
            margin-top: 4px;
            display: flex;
            flex-direction: column;
            gap: 6px;
            border-top: 1px solid rgba(201, 168, 76, 0.08);
          "
        ></div>
      
      </div>

      <!-- RENDER QUEUE -->
      <div id="render-queue-workspace" class="timeline-row" style="grid-column: 1 / -1; margin-top:12px;">
        <div class="timeline-header">
          <span class="panel-title" style="font-size:15px;letter-spacing:5px;">
            Render Queue
          </span>

          <div style="display:flex;gap:8px;margin-left:16px;">
            <button
              id="btn-clear-render-queue"
              style="
                background:transparent;
                border:1px solid var(--border);
                color:var(--text-muted);
                font-family:Rajdhani,sans-serif;
                font-size:12px;
                letter-spacing:2px;
                text-transform:uppercase;
                padding:3px 10px;
                border-radius:2px;
                cursor:pointer;
              "
            >
              Clear Queue
            </button>
          </div>

          <span id="rq-count" class="tl-time">0 Jobs</span>
        </div>

        <div
          id="render-queue-panel"
          style="
            padding:14px 20px;
            display:flex;
            flex-direction:column;
            gap:8px;
          "
        ></div>
      </div>
</div>
    </div>

    <div class="bottom-bar"></div>

    
  
</body>
</html>
<style>
  .tl-shot-card.dragging {
    opacity: 0.55 !important;
    transform: scale(0.985);
    box-shadow: 0 0 18px rgba(201, 168, 76, 0.45);
    border: 1px solid var(--gold) !important;
  }

  .tl-shot-card.drop-target {
    border: 1px dashed var(--gold) !important;
    box-shadow: inset 0 0 18px rgba(201, 168, 76, 0.25);
    position: relative;
  }

  .tl-shot-card.drop-target::before {
    content: "DROP HERE";
    position: absolute;
    top: -10px;
    left: 14px;
    background: var(--bg);
    color: var(--gold);
    font-size: 10px;
    letter-spacing: 2px;
    padding: 1px 6px;
  }
</style>
<script src="app.js"></script>
<script src="project-battery.js"></script>
<script src="shot-builder.js"></script>
<script src="voice-lab.js"></script>
<script src="timeline.js"></script>
<script src="render-queue.js"></script>
