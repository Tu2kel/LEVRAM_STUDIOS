(function () {
  function ready(fn) {
    if (document.readyState !== "loading") fn();
    else document.addEventListener("DOMContentLoaded", fn);
  }

  ready(() => {
    const preview = document.querySelector(".preview-row");
    const timeline = document.getElementById("timeline-workspace");
    const queue = document.getElementById("render-queue-workspace");

    const panels = [
      ["preview", "Preview", preview],
      ["timeline", "Timeline", timeline],
      ["queue", "Render Queue", queue],
    ].filter(x => x[2]);

    document.querySelector(".workspace-tabs-bar")?.remove();

    const bar = document.createElement("div");
    bar.className = "workspace-tabs-bar";

    function show(key) {
      panels.forEach(([k, label, el]) => {
        el.style.display = k === key ? "" : "none";
      });

      bar.querySelectorAll("button").forEach(btn => {
        btn.classList.toggle("active", btn.dataset.tab === key);
      });
    }

    panels.forEach(([key, label]) => {
      const btn = document.createElement("button");
      btn.className = "workspace-tab-btn";
      btn.dataset.tab = key;
      btn.textContent = label;
      btn.onclick = () => show(key);
      bar.appendChild(btn);
    });

    panels[0][2].before(bar);
    show("preview");
  });
})();
