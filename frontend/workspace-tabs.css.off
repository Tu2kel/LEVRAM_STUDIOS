.workspace-tabs-bar {
  display: flex;
  gap: 8px;
  padding: 10px 18px;
  border-top: 1px solid rgba(201,168,76,.35);
  border-bottom: 1px solid rgba(201,168,76,.35);
  background: rgba(247,241,231,.92);
}

.workspace-tab-btn {
  border: 1px solid rgba(201,168,76,.55);
  background: #f7f1e7;
  color: #7b4f00;
  padding: 8px 14px;
  font-size: 11px;
  letter-spacing: 2px;
  text-transform: uppercase;
  cursor: pointer;
}

.workspace-tab-btn.active {
  background: #8b001c;
  color: #f9f295;
  border-color: #C9A84C;
}

.workspace-panel-hidden {
  display: none !important;
}
